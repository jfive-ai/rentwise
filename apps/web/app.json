{
  "expo": {
    "name": "RentWise",
    "slug": "rentwise",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "rentwise",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ylee89.rentwise"
    },
    "android": {
      "package": "com.ylee89.rentwise"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:8000",
      "mapTilesUrl": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
      "mapTilesAttribution": "© OpenStreetMap contributors"
    }
  }
}
