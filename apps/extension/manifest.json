{
  "manifest_version": 3,
  "name": "RentWise Capture",
  "version": "0.1.0",
  "description": "Captures rental listings from pages you already visit in your own browser. Local-only; sends to your RentWise instance.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://rentals.ca/*",
    "https://www.padmapper.com/*",
    "https://www.zumper.com/*",
    "https://www.rew.ca/*",
    "https://liv.rent/*",
    "https://www.facebook.com/marketplace/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://rentals.ca/*"],
      "js": ["src/content/sites/rentals_ca.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.padmapper.com/*"],
      "js": ["src/content/sites/padmapper.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.zumper.com/*"],
      "js": ["src/content/sites/zumper.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.rew.ca/*"],
      "js": ["src/content/sites/rew_ca.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://liv.rent/*"],
      "js": ["src/content/sites/liv_rent.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/marketplace/*"],
      "js": ["src/content/sites/facebook_marketplace.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "RentWise Capture"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
