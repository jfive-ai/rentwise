# RentWise environment configuration
# Copy to .env (which is git-ignored) and fill in the bits you need.

ENVIRONMENT=dev
DEBUG=true

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/rentwise.db

# ---------------------------------------------------------------------------
# LLM (Phase 2)
# Provider selection happens at first run via the in-app wizard, but you can
# pre-seed defaults here. See docs/llm-providers.md for the full matrix.
# ---------------------------------------------------------------------------
RENTWISE_LLM_MODEL=openrouter/qwen/qwen3-next-80b-a3b-instruct:free
RENTWISE_LLM_FALLBACK_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free

# Fernet key for encrypting LLM API keys at rest. Required for any settings
# persistence. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# RENTWISE_SETTINGS_ENCRYPTION_KEY=

# Provider API keys — set whichever you actually use.
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Phase 4 enrichment
# ---------------------------------------------------------------------------
RENTWISE_GEOCODE_ENABLED=true
RENTWISE_GEOCODE_TIMEOUT_SECONDS=5.0
RENTWISE_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
RENTWISE_GEOCODE_CACHE_TTL_DAYS=30

RENTWISE_PHOTO_HASH_ENABLED=true
RENTWISE_PHOTO_HASH_TIMEOUT_SECONDS=5.0
RENTWISE_PHOTO_HASH_CACHE_TTL_DAYS=90

RENTWISE_DEDUP_ENABLED=true
RENTWISE_DEDUP_CONFIDENCE_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# Phase 8 PR-C: Rentals.ca direct adapter (scaffold, disabled by default)
# TOS § 3.16 prohibits automated extraction; opting in is a deliberate
# personal-use choice. robots.txt is permissive on listing pages but
# disallows *-feed.json, *-feed.xml, and pages with `bbox=`/`amenities=`/
# `types=` query params. Selectors require manual calibration before use.
# See docs/operational-rules.md "Source notes — Rentals.ca".
# ---------------------------------------------------------------------------
# RENTWISE_RENTALSCA_ENABLED=false

# ---------------------------------------------------------------------------
# Phase 8 PR-D: PadMapper direct adapter (scaffold, disabled by default)
# Owned by Zumper Inc.; TOS § 8.4 prohibits scraping. robots.txt allows
# /rentals/... and /buildings/... listing pages but disallows /api,
# /backlinks, /external, /static, cost-calculator paths, and any URL with
# a `box=` query parameter. See docs/operational-rules.md before enabling.
# ---------------------------------------------------------------------------
# RENTWISE_PADMAPPER_ENABLED=false

# ---------------------------------------------------------------------------
# Phase 8 PR-E direct adapters (Zumper / REW.ca / liv.rent)
# All three are scaffolds, disabled by default. Read the per-site notes in
# docs/operational-rules.md before flipping any of these on. Opting in
# does not produce listings yet — the extractors are stubs.
# ---------------------------------------------------------------------------
# RENTWISE_ZUMPER_ENABLED=false
# RENTWISE_REW_ENABLED=false
# RENTWISE_LIVRENT_ENABLED=false

# ---------------------------------------------------------------------------
# Phase 5 saved-search alerts (SMTP + scheduler)
# Set RENTWISE_SCHEDULER_ENABLED=true to start the in-process scheduler at
# app boot. Off by default so tests / CI never wake real intervals.
# ---------------------------------------------------------------------------
RENTWISE_SCHEDULER_ENABLED=false
RENTWISE_ALERTS_FROM=RentWise <noreply@rentwise.local>
RENTWISE_ALERTS_APP_BASE_URL=http://localhost:8081

# RENTWISE_SMTP_HOST=smtp.example.com
RENTWISE_SMTP_PORT=587
RENTWISE_SMTP_STARTTLS=true
# RENTWISE_SMTP_USERNAME=
# RENTWISE_SMTP_PASSWORD=
