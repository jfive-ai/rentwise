# RentWise environment configuration
ENVIRONMENT=dev
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/rentwise.db

# LLM Configuration (using OpenRouter with free models)
RENTWISE_LLM_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free
RENTWISE_LLM_FALLBACK_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free

# API Keys (optional - set if you have them)
#OPENROUTER_API_KEY= 
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
